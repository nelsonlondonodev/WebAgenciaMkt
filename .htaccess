RewriteEngine On

# 1. Force HTTPS and non-WWW (Canonical domain: nelsonlondono.es)
# Redirige todo el tráfico HTTP o www a https://nelsonlondono.es en un solo paso
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://nelsonlondono.es/$1 [L,R=301]

# 2. Redirect /index.html to root /
# Evitar contenido duplicado en la home
RewriteRule ^index\.html$ / [R=301,L]

# --- FIX SEO 404s (Google Search Console 2026) ---
# 1. Redirigir antiguas rutas indexadas de /dist/ a la raíz
RewriteRule ^dist/(.*)$ /$1 [R=301,L]

# 2. Redirigir directorio antiguo /nelson-londono/ al nuevo /cv/
RewriteRule ^nelson-londono/(.*)$ /cv/ [R=301,L]

# 3. Redirigir artículos o guías antiguas/eliminadas a secciones relevantes
RewriteRule ^articulo-ia-navidad-2025\.html$ /blog.html [R=301,L]
RewriteRule ^guia/guia-para-pdf\.html$ /guia/ [R=301,L]
RewriteRule ^guia/guia-seo-local-template\.html$ /guia/ [R=301,L]
# --------------------------------------------------

# 4. Custom 404 Page declaration
ErrorDocument 404 /404.html

# 5. Security Headers (Optional but Recommended for Hostinger/Apache)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    # Forzar el tipo MIME para CSS para evitar errores de bloqueos de seguridad
    AddType text/css .css
</IfModule>

# 6. Cache Control (Browser Caching for static assets)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/x-javascript "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresDefault "access plus 2 days"
</IfModule>